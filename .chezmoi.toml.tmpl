{{- $codespaces := env "CODESPACES" | not | not -}}
{{- $ci := env "CI" | not | not -}}

sourceDir = "{{ .chezmoi.sourceDir }}"

[data]
  name = "Juan Pablo Buritica"
  codespaces = {{ env "CODESPACES" | not | not }}
  email = "buritica@gmail.com"

[data.machine]
  hostname = "{{ .chezmoi.hostname }}"

# Capabilities — opt-in specialized workloads. Core is unconditional.
# Keep in sync with ansible group_vars. Consumed by the Brewfile in a later round.
{{- $caps := dict "work" false "make_music" false "play_games" false "media_server" false }}
{{- if eq .chezmoi.hostname "crowntail" }}
{{- $caps = dict "work" true "make_music" false "play_games" true "media_server" false }}
{{- else if eq .chezmoi.hostname "halfmoon" }}
{{- $caps = dict "work" false "make_music" false "play_games" false "media_server" true }}
{{- end }}

[data.capabilities]
  work         = {{ $caps.work }}
  make_music   = {{ $caps.make_music }}
  play_games   = {{ $caps.play_games }}
  media_server = {{ $caps.media_server }}
