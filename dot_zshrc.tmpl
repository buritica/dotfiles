# ~/.zshrc — interactive shell configuration. Managed by chezmoi.

export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="geoffgarside"

# Plugins
plugins=(
  git
  git-extras
  github
  cp
  copypath
  copyfile
  extract
  npm
  docker
  docker-compose
  colored-man-pages
)

source "$ZSH/oh-my-zsh.sh"

# ----- User configuration -----

# Editor
export EDITOR="ve"

# fzf
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# zoxide
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"

# zsh-defer (loaded via .chezmoiexternal.toml)
[ -f ~/.zsh-defer/zsh-defer.plugin.zsh ] && source ~/.zsh-defer/zsh-defer.plugin.zsh

# zsh-autosuggestions
[ -f ~/.zsh-autosuggestions/zsh-autosuggestions.zsh ] && source ~/.zsh-autosuggestions/zsh-autosuggestions.zsh

# zsh-syntax-highlighting (must load last)
[ -f ~/.zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && source ~/.zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# Prompt
PROMPT='%{$fg[cyan]%}%n@%m%{$reset_color%} %{$fg[yellow]%}%~%{$reset_color%}$(git_prompt_info) '

# Source modular config
for f in ~/.my/.exports ~/.my/.aliases ~/.my/.functions; do
  [ -f "$f" ] && source "$f"
done
