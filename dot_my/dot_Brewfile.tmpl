# =============================================================================
# Brewfile — managed by chezmoi, executed by ansible after dotfiles are applied.
# mise and chezmoi are installed by ansible bootstrap before this runs.
# =============================================================================

# -----------------------------------------------------------------------------
# CLI essentials — every machine
# -----------------------------------------------------------------------------
brew "bat"           # Syntax-highlighted cat
brew "coreutils"     # GNU core utils
brew "direnv"        # Per-directory env vars
brew "dust"          # Intuitive du
brew "duf"           # Modern df
brew "eza"           # Modern ls
brew "fd"            # Fast find
brew "findutils"     # GNU find/xargs
brew "fzf"           # Fuzzy finder
brew "gh"            # GitHub CLI
brew "git-delta"     # Better git diffs
brew "git-extras"    # Extra git commands
brew "gnu-tar"       # GNU tar
brew "gnupg"         # GPG
brew "httpie"        # HTTP client
brew "jq"            # JSON processor
brew "moreutils"     # sponge, ts, etc.
brew "ripgrep"       # Fast grep
brew "shellcheck"    # Shell script linter
brew "tldr"          # Simplified man pages
brew "tree"          # Directory tree
brew "wget"          # HTTP downloader
brew "zoxide"        # Smarter cd

# -----------------------------------------------------------------------------
# Media tools — halfmoon only
# -----------------------------------------------------------------------------
{{- if eq .machine.profile "media" }}
brew "ffmpeg"
brew "gifsicle"

# Container runtime for halfmoon services (docker-managed, not colima)
brew "docker"
brew "docker-compose"

# Server casks
cask "plex-media-server"
cask "qfinder-pro"
cask "raycast"
cask "sabnzbd"
cask "transmit"
{{- end }}

# -----------------------------------------------------------------------------
# Development workstation tools — non-server machines
# -----------------------------------------------------------------------------
{{- if ne .machine.profile "media" }}
brew "awscli"
brew "colima"
brew "docker"
brew "docker-compose"
brew "gist"
brew "go"
brew "hyperfine"     # Benchmarking
brew "mas"           # Mac App Store CLI
brew "pipx"          # Python app installer
brew "procs"         # Modern ps
brew "qemu"
brew "subversion"

# Desktop apps — all workstations
cask "1password"
cask "1password-cli"
cask "font-inconsolata"
cask "font-montserrat"
cask "font-open-sans"
cask "font-sanchez"
cask "font-source-code-pro"
cask "ghostty"
cask "google-chrome"
cask "google-drive"
cask "iterm2"
cask "obsidian"
cask "signal"
cask "stats"
cask "visual-studio-code"
cask "vlc"

# Mac App Store — all workstations
mas "1Password for Safari", id: 1569813296
mas "DaisyDisk", id: 411643860
mas "Fantastical", id: 975937182
mas "Bear", id: 1091189122
mas "GoLinks", id: 1478821913
mas "Keynote", id: 361285480
mas "Numbers", id: 361304891
mas "Pages", id: 361309726
mas "Whisper", id: 1668083311
{{- end }}

# -----------------------------------------------------------------------------
# Profile-specific extras
# -----------------------------------------------------------------------------
{{- if eq .machine.profile "home" }}
cask "discord"
cask "minecraft"
cask "spotify"
{{- end }}

{{- if eq .machine.profile "work" }}
cask "microsoft-auto-update"
cask "microsoft-office"
cask "microsoft-teams"
cask "slack"
{{- end }}
