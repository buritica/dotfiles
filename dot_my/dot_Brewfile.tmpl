# Core development tools (all machines)
# Note: mise (runtime manager) and chezmoi are installed by ansible bootstrap,
# not here — they must exist before this Brewfile runs.
brew "awscli"
brew "chezmoi"
brew "cloudflared"
brew "colima"
brew "coreutils"
brew "direnv"
brew "docker"
brew "docker-compose"
brew "findutils"
brew "gh"
brew "gist"
brew "git-extras"
brew "git-lfs"
brew "gnu-tar"
brew "gnupg"
brew "go"
brew "htop"
brew "httpie"
brew "jq"
brew "mas"
brew "moreutils"
brew "qemu"
brew "shellcheck"
brew "subversion"
# brew "tailscale"  # Disabled: requires sudo, breaks remote setup. Use Mac App Store version instead.
brew "tmux"
brew "tree"
brew "watch"
brew "wget"

{{- if eq .machine.profile "media" }}
# Video/audio processing + server tools (halfmoon only)
brew "bats-core"
brew "ffmpeg"
brew "gifsicle"
brew "nmap"
brew "signal-cli"
{{- end }}

# Modern CLI tools
brew "bat"           # Syntax-highlighted cat
brew "eza"           # Modern ls with git integration
brew "fd"            # Fast find replacement
brew "fzf"           # Fuzzy finder
brew "git-delta"     # Better git diffs
brew "ripgrep"       # Fast grep replacement
brew "zoxide"        # Smarter cd
brew "dust"          # Intuitive du
brew "duf"           # Modern df
brew "procs"         # Modern ps
brew "tldr"          # Simplified man pages
brew "hyperfine"     # Benchmarking tool

# Core applications (all machines)
